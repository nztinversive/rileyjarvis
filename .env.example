OPENAI_API_KEY=your_openai_api_key_here
EXA_API_KEY=your_exa_api_key_here
VECTOR_CODEX_SSH_TARGET=your-ssh-config-alias
VECTOR_CODEX_REPOS={"default":{"path":"/home/your-user/project","aliases":["linux","remote-box"]}}
VECTOR_CODEX_DEFAULT_REPO=default
VECTOR_CODEX_TIMEOUT_MS=1800000

# Secure Realtime session service. Use placeholders only in this tracked file.
NODE_ENV=development
VECTOR_REALTIME_HOST=127.0.0.1
VECTOR_REALTIME_PORT=8787
VECTOR_AUTH_TOKENS_JSON={"local-dev":"replace-with-at-least-32-random-characters"}
VECTOR_SAFETY_ID_SECRET=replace-with-at-least-32-random-characters
VECTOR_ALLOWED_ORIGINS=http://127.0.0.1:5173,capacitor://localhost
VECTOR_REQUEST_MAX_BYTES=1024
VECTOR_UPSTREAM_TIMEOUT_MS=10000
VECTOR_RATE_LIMIT_MAX=10
VECTOR_RATE_LIMIT_WINDOW_MS=60000

# Non-secret HTTPS origin compiled into the iOS web bundle. Never put a bearer
# credential here; provision that value through VectorSecureStorage instead.
VITE_VECTOR_BACKEND_URL=https://your-vector-backend.example
